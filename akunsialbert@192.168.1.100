# Server configurations
#
# Set `HOST` jadi `0.0.0.0` untuk production agar server dapat diakses dari luar container
# Set `CORS_ALLOWED_ORIGNS` sesuai URL frontend yang diizinkan
# Set `NODE_ENV` untuk production
# Set `REVERSE_PROXY` jadi truthy kalau berada di belakang reverse-proxy
HOST=127.0.0.1
PORT=8080
CORS_ALLOWED_ORIGINS=http://localhost:5173
NODE_ENV=
REVERSE_PROXY=0

# Database configurations
#
# Set `MYSQL_USER` dan `MYSQL_PASSWORD` sesuai dengan kredensial database production
# Set `DATABASE_URL` sesuai dengan name service database dari docker compose
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=sari_tebu
MYSQL_PASSWORD=
MYSQL_USER=

DATABASE_URL=mysql://root:root@localhost:3306/sari_tebu

# JWT configurations
#
# ACCESS_TOKEN_KEY dan REFRESH_TOKEN_KEY harus berupa secret yang panjang dan acak.
#
# Jika menggunakan OpenSSL:
# openssl rand -hex 64
#
# Atau:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
#
# Set `ACCESS_TOKEN_AGE` dan `REFRESH_TOKEN_AGE` mengikuti format yang didukung jsonwebtoken e.g. 7d, 30d, 12h, 3000
ACCESS_TOKEN_KEY=ef80497e27cb5de74a84e661b9ad24496d58c3b0a5ea3311b17375cf5c3fdc12e7247885c45d32a428d86abc55ee30ed6f5e6ca9506a3acd47e824564cbf3aeb
REFRESH_TOKEN_KEY=4828ed9f81cbb6cee449f8d5b33e1be144f80cd63b5c4040955b718a7cbdf74087c74ae29ce97db19bc464628e9231481cacc7aa9f20bc41256c349e6a5b4f0a
ACCESS_TOKEN_AGE=900
REFRESH_TOKEN_AGE=7d

# AWS configurations
#
# Set `AWS_SES_ENABLED=1` untuk pakai pengiriman email menggunakan AWS SES
# Set `AWS_SES_ENABLED=0` akan dikirimkan ke stdout
AWS_SES_ENABLED=0
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
AWS_SES_EMAIL_ADDRESS=